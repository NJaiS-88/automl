PORT=4000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dbname?retryWrites=true&w=majority
CLIENT_URL=http://localhost:5173
JWT_SECRET=use_a_long_random_string

# Render: optional — set to your service’s public https URL if Streamlit links need an explicit host.
# RENDER_EXTERNAL_URL is injected automatically on Render and is preferred when set.
# PUBLIC_BASE_URL=https://your-service.onrender.com

# Optional: mount path for persistent disk (Render paid) — keeps uploads/ and generated/ across deploys.
# DATA_DIR=/var/render/data

# Or set directories individually instead of DATA_DIR:
# UPLOADS_DIR=/path/to/uploads
# GENERATED_DIR=/path/to/generated

# Optional: repo root containing streamlit_tailored_app (default: parent of backend/)
# PROJECT_ROOT=

# Optional: Python for ML pipeline / Streamlit
# PYTHON_EXECUTABLE=/usr/bin/python3
# PYTHON=/usr/bin/python3

# Optional: Streamlit public path (must match reverse proxy)
# STREAMLIT_PUBLIC_MOUNT=streamlit-app
